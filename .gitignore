```gitignore
# Compiled and binary files
*.exe
*.dll
*.so
*.class
*.pyc
__pycache__/

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.a
*.lib

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Editor/IDE files
.vscode/
.idea/
*.userprefs

# System files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
```